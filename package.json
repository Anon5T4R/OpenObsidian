{
  "name": "open-obsidian",
  "version": "0.8.1",
  "description": "Open source Obsidian-like markdown note manager",
  "author": {
    "name": "João Ferreira",
    "email": "dev.joaoferreira@proton.me"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "icons": "node scripts/generate-icons.js",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^32.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.0.12",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.3.3",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language": "^6.10.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.25.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@lezer/highlight": "^1.2.0",
    "@types/adm-zip": "^0.5.8",
    "@types/d3": "^7.4.3",
    "@types/turndown": "^5.0.6",
    "adm-zip": "^0.5.17",
    "chokidar": "^3.6.0",
    "d3": "^7.9.0",
    "epubjs": "^0.3.93",
    "flexsearch": "^0.7.43",
    "js-yaml": "^5.2.1",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.15.0",
    "node-llama-cpp": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-html": "^16.0.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.openobsidian.app",
    "productName": "OpenObsidian",
    "icon": "resources/icon",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icons",
      "category": "Utility",
      "desktop": {
        "Name": "OpenObsidian",
        "Comment": "Open source markdown knowledge base",
        "Categories": "Utility;Office;TextEditor;",
        "Keywords": "markdown;notes;wiki;knowledge;"
      }
    },
    "flatpak": {
      "branch": "stable",
      "runtime": "org.freedesktop.Platform",
      "runtimeVersion": "23.08",
      "sdk": "org.freedesktop.Sdk",
      "base": "org.electronjs.Electron2.BaseApp",
      "baseVersion": "23.08",
      "finishArgs": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=network",
        "--device=dri",
        "--filesystem=home",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.kde.StatusNotifierWatcher"
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    }
  }
}
